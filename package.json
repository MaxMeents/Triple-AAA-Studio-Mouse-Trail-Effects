{
  "name": "aaa-mouse-trail-electron",
  "version": "1.0.0",
  "description": "Triple-A Studio Mouse Trail Lab as a system-wide overlay",
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win portable --x64"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.tripleaaa.mousetrail",
    "productName": "AAA Mouse Trail",
    "files": [
      "electron/**/*",
      "js/**/*",
      "css/**/*",
      "Triple AAA Mouse click Effects/**/*",
      "index.html",
      "package.json"
    ],
    "asarUnpack": [
      "electron/watcher.ps1"
    ],
    "win": {
      "target": [
        { "target": "portable", "arch": ["x64"] }
      ]
    },
    "portable": {
      "artifactName": "AAA-Mouse-Trail-${version}-portable.exe"
    }
  }
}
